# Beehiiv Newsletter Integration
BEEHIIV_API_KEY=your-beehiiv-api-key-here
BEEHIIV_PUBLICATION_ID=your-publication-id-here
BEEHIIV_WELCOME_AUTOMATION_ID=
# Optional: separate automation for gated lead capture (delivers PDF reports)
# Falls back to BEEHIIV_WELCOME_AUTOMATION_ID if not set
BEEHIIV_LEAD_AUTOMATION_ID=

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_SITE_NAME=AI Security Brief
# Set to true only after Beehiiv paid subscriptions are enabled for the publication.
NEXT_PUBLIC_PRO_CHECKOUT_LIVE=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Upstash Redis Rate Limiting
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-rest-token

# Optional affiliate URLs for article and tools page rendering
AFFILIATE_NORDVPN=
AFFILIATE_PUREVPN=
AFFILIATE_PROTON=
AFFILIATE_PROTON_VPN=
AFFILIATE_PROTON_MAIL=
AFFILIATE_SURFSHARK=
AFFILIATE_INCOGNI=

# LinkedIn Insight Tag + Conversion Tracking
# Partner ID — found in Campaign Manager → Account Assets → Insight Tag
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=
# Conversion event ID for "Pro Signup" — found in Campaign Manager → Conversions
NEXT_PUBLIC_LINKEDIN_CONVERSION_PRO_SIGNUP=
